# ── Property Identity ────────────────────────────────────────────────────────
# Set a unique ID and slug for each property EC2
PROPERTY_ID=1
PROPERTY_SLUG=headquarters

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (EBS mount path on EC2) ─────────────────────────────────────────
# Point to EBS-mounted volume so DB persists across EC2 restarts/replacements
DB_PATH=/opt/optima/data/optima.db

# ── Security ─────────────────────────────────────────────────────────────────
# MUST match the JWT_SECRET on the central server (optima.sclera.com)
JWT_SECRET=REPLACE_WITH_SAME_64_CHAR_SECRET_AS_CENTRAL_SERVER

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allow requests from the central portal only
ALLOWED_ORIGIN=https://optima.sclera.com

# ── Central server (for update checks and agent key validation) ───────────────
CENTRAL_SERVER_URL=https://optima.sclera.com

# ── App directory (for auto-update script) ───────────────────────────────────
APP_DIR=/opt/optima-property
