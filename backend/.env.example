# ── Property Identity ────────────────────────────────────────────────────────
PROPERTY_ID=1
PROPERTY_SLUG=headquarters

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (EBS mount path on EC2) ─────────────────────────────────────────
DB_PATH=/opt/optima/data/optima.db

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your actual domain — Nginx handles this but keep consistent
ALLOWED_ORIGIN=https://PROPERTY_SLUG.optima.sclera.com

# ── Central server (for update checks) ───────────────────────────────────────
CENTRAL_SERVER_URL=https://portal.optima.sclera.com

# ── App directory (for auto-update script) ───────────────────────────────────
APP_DIR=/opt/optima-property
