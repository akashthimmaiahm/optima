# ── Central Portal Server — optima.sclera.com ────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/opt/optima-portal/data/portal.db

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be the same secret used on ALL property EC2s
JWT_SECRET=REPLACE_WITH_SAME_64_CHAR_SECRET_ON_ALL_SERVERS

# ── CORS ──────────────────────────────────────────────────────────────────────
# Only the central portal domain — property servers use their own origin
ALLOWED_ORIGIN=https://optima.sclera.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Path to the built React frontend (run: cd frontend && npm run build)
FRONTEND_DIST=/opt/optima-portal/frontend/dist

# ── Version manifest (served to property servers for update checks) ───────────
# Update this when deploying a new release
CURRENT_VERSION=7.1.2
