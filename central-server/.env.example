# Central Portal Server — optima.sclera.com
PORT=4000
NODE_ENV=production
DB_PATH=/opt/optima-portal/data/portal.db

# MUST be the same secret used on ALL property EC2s
JWT_SECRET=REPLACE_WITH_SAME_SECRET_AS_ALL_PROPERTY_EC2S

ALLOWED_ORIGIN=https://optima.sclera.com

# Path to the built React frontend (npm run build output)
FRONTEND_DIST=/opt/optima-portal/frontend/dist
